<?xml version="1.0"?>

<robot xmlns:xacro="http://ros.org/wiki/xacro">

<link name="kinova_adapter_link"/>
<joint name="joint_base_robots" type="fixed">
       <parent link="base_link"/>
       <child link="kinova_adapter_link"/>
       <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/>
</joint>

<xacro:include filename="$(find kinova_description)/urdf/j2n4s300.xacro"/>
<xacro:j2n4s300  base_parent="kinova_adapter_link" prefix="kinova"/>

</robot>
