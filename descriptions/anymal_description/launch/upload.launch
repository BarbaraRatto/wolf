<?xml version="1.0" ?>
<launch>
	<arg name="sensors" default="true"/>
        <arg name="task_period" default="0.004"/>
        <arg name="arm_enabled" default="false"/>
        <arg name="arm_name" default="teleop"/>

	<!-- Load the sensors that measured the internal wrench in the joints -->
	<arg name="internal_wrench" default="false"/>

        <!-- send anymal urdf to param server -->
        <param name="robot_description" command="$(find xacro)/xacro --inorder '$(find anymal_description)/robots/anymal.urdf.xacro'
        arm_enabled:=$(arg arm_enabled) arm_name:=$(arg arm_name) load_force_sensors:=$(arg internal_wrench) task_period:=$(arg task_period)"/>
        
        <param name="gazebo_robot_description" command="$(find xacro)/xacro --inorder '$(find anymal_description)/robots/anymal.urdf.xacro'
        arm_enabled:=$(arg arm_enabled) arm_name:=$(arg arm_name) floating_base_link:=false sensors:=$(arg sensors) load_force_sensors:=$(arg internal_wrench) task_period:=$(arg task_period)"/>

        <!-- send anymal semantic description srdf to param server -->
        <param name="robot_semantic_description" command="$(find xacro)/xacro --inorder '$(find anymal_description)/robots/anymal.srdf.xacro'" />

</launch>

