        </inertial>  
    </link>  
    <!-- Adapter to Foot joint -->  
    <joint name="LF_ADAPTER_TO_FOOT" type="fixed">    
        <parent link="LF_ADAPTER"/>    
        <child link="lf_foot"/>
        <origin rpy="0.0 0.0 0.0" xyz="0.0 0.0 -0.32125"/>  
    </joint>  
    <!-- Foot link -->  
    <link name="lf_foot">
        <collision>      
            <origin xyz="0 0 0.02325"/>      
            <geometry>        
                <sphere radius="0.031"/>      
            </geometry>    
        </collision>  
    </link>   
