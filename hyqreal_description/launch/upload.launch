<?xml version="1.0" ?>
<launch>
        <arg name="sensors" default="false"/>

	<!-- Load the sensors that measured the internal wrench in the joints -->
	<arg name="internal_wrench" default="false"/>

	<!-- send the robot description file -->
	<!-- This is to have joints ordered according to our convention LF RF LH RH -->
	<param name="/hyqreal/robot_config" value="$(find hyqreal_description)/yarf/hyqreal_ordered.yarf"/>


	<!-- send HyQReal urdf to param server -->
        <param name="robot_description" command="$(find xacro)/xacro --inorder '$(find hyqreal_description)/robots/hyqreal.urdf.xacro' sensors:=$(arg sensors) load_force_sensors:=$(arg internal_wrench)" />
	<!-- This is to have joints ordered according to our convention LF RF LH RH -->
	<param name="hyqreal/robot_model" command="$(find xacro)/xacro --inorder '$(find hyqreal_description)/robots/hyqreal_model_ordered.urdf.xacro'"/>
</launch>

