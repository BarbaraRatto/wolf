r_joint LF_HAA {
    ref_frame {
        translation = (haa_x, haa_y, 0.0)
        rotation = (0.0, -PI/2.0, PI)
    }
}
r_joint LF_HFE {
    ref_frame {
        translation = (0.0, -haa_hfe, 0.0)
        rotation =  (PI/2.0, 0.0, 0.0)
    }
}
r_joint LF_KFE {
    ref_frame {
        translation = (upper_leg, 0.0, 0.0)
        rotation =  (0.0, 0.0, 0.0)
    }
}

r_joint RF_HAA {
    ref_frame {
        translation = (haa_x, -haa_y, 0.0)
        rotation =  (0.0, PI/2.0, 0.0)  // pi/2 around y
    }
}
r_joint RF_HFE {
    ref_frame {
        translation = (0.0, -haa_hfe, 0.0)
        rotation =  (-PI/2.0, 0.0, 0.0)
    }
}
r_joint RF_KFE {
    ref_frame {
        translation = (upper_leg, 0.0, 0.0)
        rotation =  (0.0, 0.0,  0.0)
    }
}

r_joint LH_HAA {
    ref_frame {
        translation = (-haa_x, haa_y, 0.0)
        rotation = (0.0, -PI/2.0, PI)
    }
}
r_joint LH_HFE {
    ref_frame {
        translation = (0.0, -haa_hfe, 0.0)
        rotation =  (PI/2.0, 0.0, 0.0)
    }
}
r_joint LH_KFE {
    ref_frame {
        translation = (upper_leg, 0.0, 0.0)
        rotation =  (0.0, 0.0, 0.0)
    }
}


r_joint RH_HAA {
