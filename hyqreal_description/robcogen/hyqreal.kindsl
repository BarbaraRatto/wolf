Robot HyQReal {

/*
 * Default parameter values:
 *
 *  foot_x = 0.39 [m]
 *  trunk_mass = 3.9708019e+01 [kg] (in the C++ code, this MUST BE the initial value)
 *  trunk_CoM = (0.060663, 0.000598, -0.007592)
 *	trunk_Ix  = 0.304383
 *	trunk_Iy  = 4.899863
 *	trunk_Iz  = 4.970291
 *	trunk_Ixy = 0.006527
 *	trunk_Ixz = -0.022946
 *	trunk_Iyz = 0.001581
 */

RobotBase trunk floating {
    inertia_params {
    mass = trunk_mass
    CoM = (trunk_com_x,  trunk_com_y, trunk_com_z)
    Ix  =  trunk_Ix
    Iy  =  trunk_Iy
    Iz  =  trunk_Iz
    Ixy =  trunk_Ixy
    Ixz  = trunk_Ixz
    Iyz  = trunk_Iyz
    }
    children {
        LF_hipassembly via LF_HAA
        RF_hipassembly via RF_HAA
        LH_hipassembly via LH_HAA
        RH_hipassembly via RH_HAA
    }
}

// Left Front leg
// ---------------
link LF_hipassembly {
    id = 1
    inertia_params {
        mass = 4.973275
        CoM = (-0.010027, -0.010608, 0.003644)
        Ix  = 0.011857
        Iy  = 0.016334
        Iz  = 0.017923
        Ixy =-0.000063
        Ixz = 0.000044
        Iyz = 0.000032
    }
    children {
        LF_upperleg via LF_HFE
    }
    frames {
        LF_hipassemblyCOM {
            translation = (-0.010027, -0.010608, 0.003644)
            rotation = (0.0, 0.0, 0.0)
        }
    }    
}

link LF_upperleg {
    id = 2
    inertia_params {
        mass = 5.877927
        CoM = (0.107987, -0.011459, -0.002121)
        Ix  = 0.017230
        Iy  = 0.144308
        Iz  = 0.148583
        Ixy = -0.005410
        Ixz =  0.002550
        Iyz = -0.000097
    }
    children {
        LF_lowerleg via LF_KFE
    }
    frames {
        LF_upperlegCOM {
            translation = (0.107987, -0.011459, -0.002121)
            rotation = (0.0, 0.0, 0.0)
        }
    }
}

link LF_lowerleg {
    id = 3
    inertia_params {
        mass = 1.291954
        CoM = (0.149302, -0.003801, -0.000624)
        Ix  = 0.001107
        Iy  = 0.058015
        Iz  = 0.058590
        Ixy =-0.001305
        Ixz =-0.000001
        Iyz = 0.000003
    }
    children {}
    frames {
        LF_foot {
            translation = (foot_x, 0.0, 0.0)
            rotation = (PI/2.0, -PI/2.0, 0.0)
        }
        LF_lowerlegCOM {
            translation = (0.149302, -0.003801, -0.000624)
            rotation = (0.0, 0.0, 0.0)
        }
    }
}


