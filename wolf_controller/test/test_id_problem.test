<?xml version="1.0" ?>
<launch>

    <arg name="robot_name" default="ras_1"/>

    <!-- Load the robot -->
    <include file="$(find wolf_description_utils)/launch/upload.launch">
        <arg name="robot_name"        value="$(arg robot_name)" />
        <arg name="controller_period" value="0.001" />
    </include>

   <group ns="$(arg robot_name)">
       <!-- IDProblem test -->
       <test test-name="wolf_id_problem_test"
            pkg="wolf_controller"
            type="test_id_problem"
            time-limit="80.0">
       </test>
   </group>

</launch>
