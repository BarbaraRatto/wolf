<launch>
     <arg name="robot_name" default="hyq"/>

     <!-- Load the robot stuff -->
     <include file="$(eval find(arg('robot_name') + '_description') +'/launch/upload.launch')">
        <arg name="sensors" default="false" />
     </include>

     <!-- Load the controller stuff -->
     <include file="$(find wolf_controller)/launch/wolf_controller_spawn.launch">
            <arg name="robot_name" value="$(arg robot_name)" />
     </include>

    <group ns="$(arg robot_name)">

          <!-- Controller test -->
          <test test-name="wolf_controller_test"
               pkg="wolf_controller"
               type="wolf_controller_test"
               time-limit="80.0">
         </test>

        <!-- Start the dummy robot -->
         <node name="hyq_dummy"
              pkg="wolf_controller"
              output="screen"
              type="hyq_dummy"/>

   </group>

</launch>
